# Soul House deployment environment
# Copy this file to .env.local for local development.
# In Cloudflare Pages, add the same values in Settings -> Environment variables.

# App
NODE_VERSION=20
NEXT_PUBLIC_SITE_URL=https://your-project.pages.dev
NEXT_PUBLIC_SITE_NAME="心灵小屋"
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# Supabase server-side access
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

# Security
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_EMAILS=admin@example.com
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=80

# Payment
MOCK_PAYMENT_ENABLED=true
PAYMENT_SECRET_KEY=replace-with-at-least-32-random-characters
PAYMENT_CONFIG_SECRET=replace-with-at-least-32-random-characters

# Real payment channels are intentionally disabled for first deployment.
WECHAT_PAY_ENABLED=false
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_PLATFORM_PUBLIC_KEY=
WECHAT_NOTIFY_URL=https://your-project.pages.dev/api/payments/wechat/callback

ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-project.pages.dev/api/payments/alipay/callback
ALIPAY_RETURN_URL=https://your-project.pages.dev/checkout/success
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# AI chat is reserved but hidden by default.
AI_CHAT_ENABLED=false
AI_PROVIDER=mock
AI_MODEL=mock-companion
AI_API_KEY=

# SEO verification
GOOGLE_SITE_VERIFICATION=
BAIDU_SITE_VERIFICATION=
